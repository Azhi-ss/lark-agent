# ===== LLM 接入 =====
# 方式 A：真 Anthropic Claude（填此项则优先用）
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 方式 B：火山引擎 ARK 代理（当前环境默认，无需填 key）
# 由 ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN 提供，模型映射：
#   sonnet -> glm-5.2 / opus -> minimax-m3 / haiku -> deepseek-v4-flash
# 这些变量通常由环境注入，无需在此设置。

# ===== 飞书写回安全 =====
# 1 = 允许写回飞书（默认）；0 = 仅模拟，不真正写
LARK_WRITEBACK=1

# ===== 前端 =====
# 前端 dev server 地址（CORS 白名单）
WEB_ORIGIN=http://localhost:5173

# ===== lark-cli =====
# 默认从 PATH 查找；如需指定路径：
# LARK_CLI_PATH=/usr/local/bin/lark-cli
